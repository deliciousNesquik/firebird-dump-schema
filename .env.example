# Для переменных авторизации используется стандартный префикс ISC_*.
# Это сделано намеренно — эти переменные стандартны для Firebird.
# Учётные данные читаются во время выполнения и никогда не передаются в
# аргументах команды, что защищает их от утечки через `ps aux` и другие
# средства мониторинга. После успешной выгрузки процесс очищает их из окружения.

ISC_USER=UPPER_CASE_USERNAME
ISC_PASSWORD=PASSWORD


# Адрес БД в формате Firebird.
# Для локального подключения указывается алиас или путь к файлу.
# Для удалённого подключения используется формат HOST:ALIAS_OR_PATH.

# FB_DATABASE=HOST_OR_ADDRESS:ALIAS_OR_PATH
FB_DATABASE=ALIAS_OR_PATH


# Директория, в которую сохраняется структура БД,
# разбитая по типам объектов (таблицы, представления, процедуры и т. д.).
# Абсолютный или относительный (от текущей рабочей директории) путь.
DUMP_DIR=database


# Таймаут (в секундах) на чтение метаданных. Защищает процесс от бесконечного
# зависания. Значение <= 0 отключает таймаут.
# (Только POSIX — реализовано через SIGALRM; на других платформах — заглушка.)
ISQL_TIMEOUT=300


# Кодировка соединения. По умолчанию UTF8. Для legacy-баз, где метаданные
# (имена/комментарии) хранятся в однобайтовой кодировке, укажите её явно,
# иначе чтение упадёт с UnicodeDecodeError. Частый случай — кириллица: WIN1251.
# DB_CHARSET=WIN1251
