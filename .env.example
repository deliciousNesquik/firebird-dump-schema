# Используется стандартный префикс ISC_* для переменных авторизации.
# Это намеренное решение — данные переменные являются стандартом Firebird
# и автоматически подхватываются его утилитами (isql, gbak и др.),
# что исключает необходимость явной передачи credentials в аргументах команд
# и защищает данные от утечки через ps aux или другие инструменты мониторинга.
# После успешного завершения дампа приложение выполняет unset данных переменных.

ISC_USER=UPPER_CASE_USERNAME
ISC_PASSWORD=PASSWORD

# Адрес базы данных в формате Firebird.
# Для локального подключения указывается алиас или путь к файлу.
# Для удалённого подключения используется формат HOST:ALIAS_OR_PATH.

# FB_DATABASE=HOST_OR_ADDRESS:ALIAS_OR_PATH
FB_DATABASE=ALIAS_OR_PATH

# Путь к файлу, в который будут сохранены метаданные базы данных,
# сгенерированные утилитой isql.
# Может быть абсолютным или относительным путём (относительно рабочей директории).
METADATA_FILE=metadata.sql

# Директория, в которую будет сохранена структура базы данных,
# разделённая по типу объектов (таблицы, представления, процедуры и т.д.).
# Может быть абсолютным или относительным путём (относительно рабочей директории).
DUMP_DIR=database

# Путь к исполняемому файлу isql.
# Если утилита установлена глобально и доступна в PATH,
# можно указать просто: isql
ISQL_PATH=/opt/firebird/bin/isql