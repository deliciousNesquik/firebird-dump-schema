# The standard ISC_* prefix is ​​used for authorization variables.
# This is intentional—these variables are standard in Firebird
# and are automatically picked up by its utilities (isql, gbak, etc.),
# eliminating the need to explicitly pass credentials in command arguments
# and protecting data from leakage via ps aux or other monitoring tools.
# After a successful dump, the application unsets these variables.

ISC_USER=UPPER_CASE_USERNAME
ISC_PASSWORD=PASSWORD


# Database address in Firebird format.
# For a local connection, an alias or file path is specified.
# For a remote connection, the format HOST:ALIAS_OR_PATH is used.

# FB_DATABASE=HOST_OR_ADDRESS:ALIAS_OR_PATH
FB_DATABASE=ALIAS_OR_PATH


# Path to the file where database metadata generated by the isql utility will be saved.
# Can be an absolute or relative path (relative to the working directory).
METADATA_FILE=metadata.sql

# Save or delete the file containing general metainformation about the database
METADATA_FILE_DELETE_AFTER_PROCESSING=true


# The directory where the database structure will be saved,
# separated by object type (tables, views, procedures, etc.).
# Can be an absolute or relative path (relative to the working directory).
DUMP_DIR=database


# Path to the isql executable.
# If the utility is installed globally and available in the PATH,
# you can simply specify: isql
ISQL_PATH=/opt/firebird/bin/isql